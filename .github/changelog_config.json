{
  "categories": [
    {
      "title": "## 🚀 Features & UI Updates",
      "labels": ["feature", "feat", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes & Stability",
      "labels": ["bug", "fix"]
    },
    {
      "title": "## 🛠️ Maintenance & Refactoring",
      "labels": ["chore", "refactor", "build", "ci"]
    },
    {
      "title": "## 📦 Other Changes",
      "labels": ["uncategorized"]
    }
  ],
  "ignore_labels": [
    "skip-changelog"
  ],
  "template": "${{CHANGELOG}}",
  "pr_template": "### ${{TITLE}} (#${{NUMBER}})\n\n${{BODY}}",
  "empty_template": "No pull requests were found since the last release.",
  "label_extractor": [
    {
      "pattern": "^(feat|feature|enhancement).*",
      "target": "feature",
      "on": "title"
    },
    {
      "pattern": "^(fix|bug).*",
      "target": "bug",
      "on": "title"
    },
    {
      "pattern": "^(chore|refactor|build|ci).*",
      "target": "chore",
      "on": "title"
    }
  ],
  "template_uncategorized": "### ${{TITLE}} (#${{NUMBER}})\n\n${{BODY}}",
  "category_uncategorized": "uncategorized",
  "tag_resolver": {
    "method": "semver"
  }
}
